# ──────────────────────────────────────────────────────
#  Copy this file to .env and fill in your real values
#  DO NOT commit the .env file to version control!
# ──────────────────────────────────────────────────────

PORT=5000
MONGODB_URI=mongodb://localhost:27017/saas_dashboard

# Generate strong random secrets for production!
# e.g.  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRE=1d
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRE=7d

NODE_ENV=development
